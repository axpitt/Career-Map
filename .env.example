# CareerMap AI - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Google Gemini API Configuration
GEMINI_API_KEY=your_google_gemini_api_key_here

# Application Configuration
APP_NAME=CareerMap AI
DEBUG=false
LOG_LEVEL=INFO

# Security Configuration
SECRET_KEY=your_secret_key_here_generate_a_random_string
# Optional API key for backend access. If using a public static frontend, do not expose this value in browser-side code.
API_KEY=your_api_key_here_for_frontend_authentication

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_MINUTES=60

# File Upload Configuration
MAX_FILE_SIZE_MB=10

# CORS Configuration (for production)
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://your-frontend-domain-2.com